# basketch environment variables
# Copy this to .env and fill in your Supabase credentials

# --- Pipeline (used by GitHub Actions + local development) ---
# Get from: supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Frontend (Vite) ---
# VITE_ prefix makes them available in browser code
# These are safe for the frontend (read-only access via RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- GitHub Actions Secrets (not in .env, configure in GitHub) ---
# SUPABASE_URL          -> Settings > Secrets > Actions
# SUPABASE_SERVICE_ROLE_KEY -> Settings > Secrets > Actions
# WARNING: SUPABASE_SERVICE_ROLE_KEY grants full write access.
#          NEVER expose it in frontend code or public repositories.
