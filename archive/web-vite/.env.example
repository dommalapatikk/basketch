# basketch frontend environment variables
# Copy this to .env and fill in your Supabase credentials
#
# VITE_ prefix makes these available in browser code via import.meta.env
# These are safe for the frontend (read-only access via RLS)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
